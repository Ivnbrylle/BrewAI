# ==============================================================================
# BrewAI Portfolio Prototype - Master Environment Blueprint
# ==============================================================================

# Application Execution Mode
NODE_ENV=development
APP_PORT=8000

# Relational Persistence Layer (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=brewadmin
DB_PASSWORD=change_this_locally_secure_password
DB_NAME=brewai_db

# Vector Space Engine (Qdrant)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# AI Pipeline Settings (Switching between Offline Ollama and Cloud Bedrock)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
AWS_REGION=us-east-1